{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },

    "AllowedHosts": "*",

    "HealthChecksUI": {
        "HealthChecks": [
            {
                "Name": "LinkSummary.Proxy",
                "Uri": "http://localhost:5228/health"
            }
        ],
        "EvaluationTimeInSeconds": 15,
        "MinimumSecondsBetweenFailureNotifications": 300
    },

    "Telegram": {
        "BotToken": "",
        "ChatId": ""
    }
}
