{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },

    "AllowedHosts": "*",

    "HealthChecksUI": {
        "HealthChecks": [
            {
                "Name": "LinkSummary.Proxy",
                "Uri": "http://link_summary_api:8080/health"
            },
            {
                "Name": "Analitics.Database",
                "Uri": "http://analytics_api:8080/health"
            }
        ],
        "EvaluationTimeInSeconds": 65,
        "MinimumSecondsBetweenFailureNotifications": 3600
    },

    "Telegram": {
        "BotToken": "",
        "ChatId": ""
    }
}
